# Environment Variables Template

# Copy this file to `.env` and fill in your actual values
# IMPORTANT: .env is in .gitignore and should NEVER be committed

# =========================
# Kaggle Credentials
# =========================
# Get from: https://www.kaggle.com/settings/account
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# =========================
# Database Connection (Future Use - Week 3+)
# =========================
# DATABASE_URL=postgresql://user:password@localhost:5432/food_demand_db
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/database

# =========================
# API Keys (Future Use - Week 3+)
# =========================
# WEATHER_API_KEY=your-weather-api-key
# AZURE_API_KEY=your-azure-key

# =========================
# Application Settings
# =========================
DEBUG=False
ENVIRONMENT=development  # development, staging, production

# =========================
# File Paths
# =========================
DATA_DIR=./data
OUTPUT_DIR=./outputs
MODEL_DIR=./models

# =========================
# Model Parameters (Future Use)
# =========================
# TEST_SIZE=0.2
# RANDOM_STATE=42
# MAX_WORKERS=4

# =========================
# Logging
# =========================
# LOG_LEVEL=INFO
# LOG_FILE=./logs/app.log